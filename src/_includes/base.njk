<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "SolarPicks - Best Portable Solar & Off-Grid Power Guides" }}</title>
  <meta name="description" description="{{ description or 'Expert reviews and buying guides for portable solar panels, solar generators, and off-grid power solutions.' }}">
  <meta name="keywords" content="{{ keywords or 'portable solar, solar generator, off-grid power, Jackery, EcoFlow, Bluetti' }}">
  <link rel="canonical" href="https://solarpicks.net{{ page.url }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or 'SolarPicks' }}">
  <meta property="og:description" content="{{ description or 'Best portable solar & off-grid power guides' }}">
  <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://solarpicks.net{{ page.url }}">
  
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{% if tags and 'post' in tags %}Article{% else %}WebSite{% endif %}",
    "headline": "{{ title or 'SolarPicks' }}",
    "description": "{{ description or 'Best portable solar & off-grid power guides' }}",
    "url": "https://solarpicks.net{{ page.url }}",
    "author": { "@type": "Organization", "name": "SolarPicks" },
    "publisher": { "@type": "Organization", "name": "SolarPicks" }
    {% if date %},"datePublished": "{{ date | date('YYYY-MM-DD') }}"{% endif %}
  }
  </script>
  
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <nav class="container">
      <a href="/" class="logo">☀️ SolarPicks</a>
      <ul class="nav-links">
        <li><a href="/category/solar-generators/">Solar Generators</a></li>
        <li><a href="/category/solar-panels/">Solar Panels</a></li>
        <li><a href="/category/power-stations/">Power Stations</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>
  </header>
  
  <main class="container">
    {{ content | safe }}
  </main>
  
  <footer>
    <div class="container">
      <p>&copy; 2026 SolarPicks. All rights reserved.</p>
      <p class="disclaimer">As an Amazon Associate, we earn from qualifying purchases. This site also participates in other affiliate programs.</p>
    </div>
  </footer>
</body>
</html>