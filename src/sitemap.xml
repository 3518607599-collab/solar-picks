---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.w3.org/2000/svg">
{%- for page in collections.all %}
  <url>
    <loc>https://solarpicks.net{{ page.url }}</loc>
    <lastmod>{{ page.date | date('YYYY-MM-DD') }}</lastmod>
    <changefreq>{% if page.data.layout %}monthly{% else %}weekly{% endif %}</changefreq>
    <priority>{% if page.url == '/' %}1.0{% elif page.data.layout %}0.8{% else %}0.5{% endif %}</priority>
  </url>
{%- endfor %}
</urlset>